# ===== CareerPilot AI environment =====
# Copy to .env and fill in real values. Never commit .env.

# --- Core secrets ---
JWT_SECRET=af83a9a313dcdc9203bd93f22e59a70ecd3e6a1d44af61d1917e0a125806c97296e53ad1b12bb03af7bb7ce94ce501d4
GEMINI_API_KEY=your-google-gemini-api-key

# --- Database (Neon serverless Postgres) ---
# Using the DIRECT endpoint (no `-pooler` in hostname) because Flyway DDL and
# LangGraph's PostgresSaver use prepared statements that break under Neon's
# pgBouncer transaction-mode pooler. Switch to the pooler endpoint later only
# for app read paths if you need it.
POSTGRES_DB=neondb
POSTGRES_USER=neondb_owner
POSTGRES_PASSWORD=npg_V9LBbpN6ZAyU
DATABASE_URL=jdbc:postgresql://ep-falling-haze-aq84svji.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channelBinding=require
DATABASE_URL_PY=postgresql://neondb_owner:npg_V9LBbpN6ZAyU@ep-falling-haze-aq84svji.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- Storage (S3 / MinIO for local) ---
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=careerpilot
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- Agent service ---
AGENT_SERVICE_URL=http://agent-service:8088
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-pro

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080
