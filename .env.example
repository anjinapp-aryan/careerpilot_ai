# ===== CareerPilot AI environment =====
# Copy to .env and fill in real values. Never commit .env.

# --- Core secrets ---
# Generate with:  openssl rand -hex 48     (must be >= 32 chars, JwtService refuses to start otherwise)
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars-long-aaaaaaaaaa
# Get one for free at https://aistudio.google.com/apikey (no credit card)
GEMINI_API_KEY=your-google-gemini-api-key

# --- Database (Neon serverless Postgres by default) ---
# Default: external Neon Postgres. The local `postgres` service has been removed
# from docker-compose.yml. Use the DIRECT endpoint (no `-pooler` in hostname) —
# Flyway DDL and LangGraph's PostgresSaver rely on prepared statements that
# break under Neon's pgBouncer transaction-mode pooler.
#
# Neon URL format (from Neon dashboard > Connection Details):
#   postgresql://<user>:<pass>@<host>/<db>?sslmode=require&channel_binding=require
#
# JDBC URL: spell the SSL flag camelCase (channelBinding), not snake_case.
POSTGRES_DB=neondb
POSTGRES_USER=neondb_owner
POSTGRES_PASSWORD=your-neon-password
DATABASE_URL=jdbc:postgresql://YOUR-NEON-HOST.neon.tech/neondb?sslmode=require&channelBinding=require
DATABASE_URL_PY=postgresql://neondb_owner:your-neon-password@YOUR-NEON-HOST.neon.tech/neondb?sslmode=require&channel_binding=require

# To go back to a LOCAL Postgres instead of Neon:
#   1. Re-add the postgres service in docker-compose.yml (see git history of that file).
#   2. Replace the four lines above with:
#        POSTGRES_DB=careerpilot
#        POSTGRES_USER=careerpilot
#        POSTGRES_PASSWORD=careerpilot
#        DATABASE_URL=jdbc:postgresql://postgres:5432/careerpilot
#        DATABASE_URL_PY=postgresql://careerpilot:careerpilot@postgres:5432/careerpilot

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- Storage (S3 / MinIO for local) ---
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=careerpilot
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- Agent service ---
AGENT_SERVICE_URL=http://agent-service:8088
AI_PROVIDER=gemini
# gemini-2.5-pro is the default; switch to gemini-2.5-flash for cheaper/faster runs during development.
AI_MODEL=gemini-2.5-pro

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080
